{
  "name": "flowmatic-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 4000",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "lint:report": "eslint --format json --output-file eslint-report.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "sonar": "npm run lint:report && npm run test:coverage && node sonar-scanner.js",
    "sonar:local": "npm run lint:report && npm run test:coverage && node sonar-scanner.js"
  },
  "dependencies": {
    "next": "15.5.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "15.5.3",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.6",
    "sonarqube-scanner": "^4.3.2",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6",
    "vitest": "^1.6.1"
  }
}
